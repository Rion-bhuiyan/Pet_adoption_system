@{
    ViewBag.Title = "Home Page";
}

<section class="py-5 bg-light">

    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold text-primary">Pet Haven Gallery</h2>
            <p class="text-muted">Meet adorable pets waiting for a loving home</p>
        </div>

