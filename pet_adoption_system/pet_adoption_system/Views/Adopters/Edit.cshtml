@model pet_adoption_system.Models.View_Model.AdopterVM
@{
    ViewBag.Title = "Edit";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header text-white text-center py-4"
                     style="background: linear-gradient(135deg, #6ab7f5 0%, #34d1bf 100%);">
                    <h2 class="mb-0 fw-bold">Edit Adopter</h2>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">
                    @using (Ajax.BeginForm("Edit", "Adopters", new AjaxOptions
                    {
                        HttpMethod = "POST",
                        InsertionMode = InsertionMode.Replace,
                        UpdateTargetId = "msg",
                        OnComplete = "clearAll"
                    }, new { enctype = "multipart/form-data", id = "form0" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(x => x.AdopterId)
                        @Html.HiddenFor(x => x.Picture)

                        <div class="row align-items-start">
                            <div class="col-6">
                                <div class="row mb-3">
                                    @Html.LabelFor(x => x.AdopterName, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-3 fw-bold" })
                                    <div class="col-9">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-primary-subtle">
                                                <i class="bi bi-person-fill text-primary"></i>
                                            </span>
                                            @Html.TextBoxFor(x => x.AdopterName, new { @class = "form-control form-control-sm border-primary-subtle" })
                                        </div>
                                        @Html.ValidationMessageFor(x => x.AdopterName, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    @Html.LabelFor(x => x.BirthDate, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-3 fw-bold" })
                                    <div class="col-9">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-primary-subtle">
                                                <i class="bi bi-calendar-event-fill text-primary"></i>
                                            </span>
                                            @Html.TextBoxFor(x => x.BirthDate, "{0:yyyy-MM-dd}", new { @class = "form-control form-control-sm border-primary-subtle", type = "date" })
                                        </div>
                                        @Html.ValidationMessageFor(x => x.BirthDate, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    @Html.LabelFor(x => x.Age, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-3 fw-bold" })
                                    <div class="col-9">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-primary-subtle">
                                                <i class="bi bi-heart-pulse-fill text-primary"></i>
                                            </span>
                                            @Html.TextBoxFor(x => x.Age, new { @class = "form-control form-control-sm border-primary-subtle" })
                                        </div>
                                        @Html.ValidationMessageFor(x => x.Age, "", new { @class = "text-danger small" })
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    @Html.LabelFor(x => x.PictureFile, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-3 fw-bold" })
                                    <div class="col-9">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-primary-subtle">
                                                <i class="bi bi-image-fill text-primary"></i>
                                            </span>
                                            @Html.TextBoxFor(x => x.PictureFile, new { @class = "form-control form-control-sm border-primary-subtle", type = "file" })
                                        </div>
                                        @Html.ValidationMessageFor(x => x.PictureFile, "", new { @class = "text-danger small" })

                                        @if (!string.IsNullOrEmpty(Model.Picture))
                                        {
                                            <div class="mt-3">
                                                <img src="@Url.Content(Model.Picture)" alt="Adopter Image" class="img-thumbnail shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" />
                                                <p class="text-muted small mt-1">Current Image</p>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="row mb-4">
                                    @Html.LabelFor(x => x.Maritalstatus, htmlAttributes: new { @class = "col-form-label col-form-label-sm col-3 fw-bold" })
                                    <div class="col-9 d-flex align-items-center">
                                        @Html.CheckBoxFor(x => x.Maritalstatus, new { @class = "form-check-input me-2" })
                                        <label class="form-check-label">Married</label>
                                        @Html.ValidationMessageFor(x => x.Maritalstatus, "", new { @class = "text-danger small ms-2" })
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-9 offset-3">
                                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                                            <i class="bi bi-save me-2"></i> Update
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 ps-4 border-start">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold text-secondary mb-0">Select Pets</h5>
                                    <a class="btn btn-primary btn-sm rounded-circle shadow-sm" href="#" id="btnPlus">
                                        <i class="fa fa-plus"></i>
                                    </a>
                                </div>

                                <div id="PetContainer" style="width:100%">
                                    @foreach (var item in Model.PetList)
                                    {
                                        @Html.Action("AddNewPet", "Adopters", new { id = item })
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="row mt-4">
                        <div class="col-12">
                            <div id="msg" class="text-center"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $("#form0").attr("enctype", "multipart/form-data");

        $(document).off("click", "#btnPlus").on("click", "#btnPlus", function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();

            $.ajax({
                url: "/Adopters/AddNewPet",
                type: "GET",
                success: function (res) {
                    $("#PetContainer").append(res);
                }
            });
        });

        $(document).off("click", "#btnDelete").on("click", "#btnDelete", function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
            $(this).closest(".row").remove();
        });

        function clearAll() {
        }
    </script>
}