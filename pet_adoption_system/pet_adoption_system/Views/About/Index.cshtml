
@{
    ViewBag.Title = "Index";
}

<section id="about-section" class="py-5 bg-light">

    <div class="container">

        <div class="text-center mb-5">
            <h6 class="text-primary fw-bold text-uppercase">About Us</h6>
            <h2 class="fw-bold">Welcome to <span class="text-success">Pet Haven</span></h2>
            <p class="text-muted">
                A caring place where pets find loving families and people find their perfect companions.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card border border-3 shadow-sm h-100 text-center">
                    <div class="card-body">

                        <i class="bi bi-heart-fill text-danger display-5 mb-3"></i>

                        <h5 class="fw-bold">Compassionate Care</h5>

                        <p class="text-muted">
                            Every pet receives love, care, and attention while waiting for their forever home.
                        </p>

                    </div>
                </div>
            </div>


            <div class="col-md-4">
                <div class="card border border-3 shadow-sm h-100 text-center">
                    <div class="card-body">

                        <i class="bi bi-house-heart text-primary display-5 mb-3"></i>

                        <h5 class="fw-bold">Safe Adoption</h5>

                        <p class="text-muted">
                            Our adoption process ensures every pet is matched with a responsible family.
                        </p>

                    </div>
                </div>
            </div>


            <div class="col-md-4">
                <div class="card border border-3 shadow-sm h-100 text-center">
                    <div class="card-body">

                        <i class="bi bi-shield-check text-success display-5 mb-3"></i>

                        <h5 class="fw-bold">Trusted Community</h5>

                        <p class="text-muted">
                            We partner with shelters and rescuers to build a safe adoption community.
                        </p>

                    </div>
                </div>
            </div>

        </div>


        <div class="row mt-5 g-4">

            <div class="col-md-3">
                <div class="border border-3 rounded text-center p-4 bg-white shadow-sm">
                    <h3 class="text-primary fw-bold">500+</h3>
                    <p class="mb-0 text-muted">Pets Adopted</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="border border-3 rounded text-center p-4 bg-white shadow-sm">
                    <h3 class="text-success fw-bold">120+</h3>
                    <p class="mb-0 text-muted">Happy Families</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="border border-3 rounded text-center p-4 bg-white shadow-sm">
                    <h3 class="text-danger fw-bold">80+</h3>
                    <p class="mb-0 text-muted">Rescued Pets</p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="border border-3 rounded text-center p-4 bg-white shadow-sm">
                    <h3 class="text-warning fw-bold">24/7</h3>
                    <p class="mb-0 text-muted">Support</p>
                </div>
            </div>

        </div>


        <div class="text-center mt-5">

            <a class="btn btn-primary btn-lg rounded-pill px-4"
               data-bs-toggle="collapse"
               href="#moreAbout"
               role="button"
               aria-expanded="false"
               aria-controls="moreAbout">
                Learn More About Us
            </a>

        </div>



        <div class="collapse mt-5" id="moreAbout">

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="card border border-3 shadow-sm text-center h-100">
                        <div class="card-body">

                            <i class="bi bi-paw-fill text-success display-6 mb-3"></i>

                            <h5 class="fw-bold">Pet Welfare</h5>

                            <p class="text-muted">
                                We ensure every pet is healthy, vaccinated, and ready for a safe new home.
                            </p>

                        </div>
                    </div>
                </div>


                <div class="col-md-4">
                    <div class="card border border-3 shadow-sm text-center h-100">
                        <div class="card-body">

                            <i class="bi bi-people-fill text-primary display-6 mb-3"></i>

                            <h5 class="fw-bold">Community Support</h5>

                            <p class="text-muted">
                                We work with shelters, volunteers, and animal lovers to save more lives.
                            </p>

                        </div>
                    </div>
                </div>


                <div class="col-md-4">
                    <div class="card border border-3 shadow-sm text-center h-100">
                        <div class="card-body">

                            <i class="bi bi-heart-pulse-fill text-danger display-6 mb-3"></i>

                            <h5 class="fw-bold">Healthy Pets</h5>

                            <p class="text-muted">
                                Each pet receives proper medical care before being placed for adoption.
                            </p>

                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>

</section>

