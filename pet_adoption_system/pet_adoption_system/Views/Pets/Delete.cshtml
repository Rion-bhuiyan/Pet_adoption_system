@model pet_adoption_system.Models.Pet
@{
    ViewBag.Title = "Delete Pet";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-header bg-danger text-white text-center py-3">
                    <h4 class="mb-0">Confirm Delete</h4>
                </div>

                <div class="card-body p-4 text-center">
                    <h5 class="text-muted mb-4">Are you sure you want to delete this pet?</h5>

                    <div class="border rounded p-3 bg-light mb-4">
                        <dl class="row text-start">
                            <dt class="col-sm-4 fw-semibold text-muted">
                                @Html.DisplayNameFor(model => model.PetName)
                            </dt>
                            <dd class="col-sm-8">
                                <strong>@Html.DisplayFor(model => model.PetName)</strong>
                            </dd>

                            <dt class="col-sm-4 fw-semibold text-muted mt-2">
                                @Html.DisplayNameFor(model => model.AdoptionFee)
                            </dt>
                            <dd class="col-sm-8 mt-2">
                                <strong>@Html.DisplayFor(model => model.AdoptionFee) BDT</strong>
                            </dd>
                        </dl>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="d-flex justify-content-between">
                            <!-- Left Button: Cancel / Back -->
                            @Html.ActionLink("Cancel / Back to List", "Index", null, new { @class = "btn btn-outline-secondary btn-lg rounded-pill px-5 fw-bold" })

                            <!-- Right Button: Yes, Delete -->
                            <input type="submit" value="Yes, Delete" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm" />
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>