@model pet_adoption_system.Models.Pet
@{
    ViewBag.Title = "Create Pet";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Add New Pet</h4>
                </div>

                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                        <div class="mb-3">
                            @Html.LabelFor(model => model.PetName, new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.PetName, new { htmlAttributes = new { @class = "form-control", placeholder = "Pet's name (e.g. Max)" } })
                            @Html.ValidationMessageFor(model => model.PetName, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <div class="mb-4">
                            @Html.LabelFor(model => model.AdoptionFee, new { @class = "form-label fw-semibold" })
                            @Html.EditorFor(model => model.AdoptionFee, new { htmlAttributes = new { @class = "form-control", placeholder = "Adoption fee (e.g. 5000)" } })
                            @Html.ValidationMessageFor(model => model.AdoptionFee, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <div class="d-grid">
                            <input type="submit" value="Create Pet" class="btn btn-primary btn-lg rounded-pill fw-bold" />
                        </div>
                    }
                </div>

                <div class="card-footer bg-transparent border-0 text-center py-3">
                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    
}