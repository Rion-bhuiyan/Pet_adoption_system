
@model IEnumerable<pet_adoption_system.Models.Pet>

@{
    ViewBag.Title = "Pets";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center ">
            <h4 class="mb-1">Pet Adoption List</h4>

            @Html.ActionLink("Create New Pet", "Create", null, new { @class = "btn btn-success btn-sm fw-bold" })
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-striped table-hover align-middle">

                    <thead class="table-info">
                        <tr>
                            <th>
                                @Html.DisplayNameFor(model => model.PetName)
                            </th>

                            <th>
                                @Html.DisplayNameFor(model => model.AdoptionFee)
                            </th>

                            <th class="text-center">
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                     @Html.DisplayFor(modelItem => item.PetName)
                                </td>

                                <td>
                                    <span class="badge bg-success fs-6">
                                        $@Html.DisplayFor(modelItem => item.AdoptionFee)
                                    </span>
                                </td>

                                <td class="text-center">

                                    @Html.ActionLink("Edit", "Edit", new { id = item.PetId }, new { @class = "btn btn-warning btn-sm me-1" })

                                    @Html.ActionLink("Details", "Details", new { id = item.PetId }, new { @class = "btn btn-info btn-sm text-white me-1" })

                                    @Html.ActionLink("Delete", "Delete", new { id = item.PetId }, new { @class = "btn btn-danger btn-sm" })

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
